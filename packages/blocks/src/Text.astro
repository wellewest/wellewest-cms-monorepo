---
import RichText from './RichText.astro'
interface Props { block: any }
const { block } = Astro.props
const widthClass = `text--${block.width || 'narrow'}`
---

<section class={`text ${widthClass}`}>
  <div class="container">
    {block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
    {block.heading && <h2>{block.heading}</h2>}
    <RichText data={block.body} />
  </div>
</section>

<style>
  .text { padding: 3rem 0; }
  .text .container { display: flex; flex-direction: column; align-items: center; }
  .text :global(.rt), .text h2, .text .eyebrow { width: 100%; }
  .text--narrow :global(.rt), .text--narrow h2, .text--narrow .eyebrow { max-width: 65ch; }
  .text--normal :global(.rt), .text--normal h2, .text--normal .eyebrow { max-width: 80ch; }
  .text--wide :global(.rt), .text--wide h2, .text--wide .eyebrow { max-width: 100%; }
</style>
